from pathlib import Path
import os

REPO_ROOT = Path(__file__).resolve().parents[3]
RUN_DIR = REPO_ROOT / 'runs' / 'feature_set_aaforecast_brentoil_case1_aaforecast'
FORECASTS = RUN_DIR / 'cv' / 'AAForecast_forecasts.csv'
OUT_DIR = REPO_ROOT / '.omx' / 'research' / 'research-20260401-brent-aaf-h6h8' / 'autoresearch_eval'
OUT_DIR.mkdir(parents=True, exist_ok=True)
THRESHOLDS = {6: 3.0, 7: 5.0, 8: 5.0}

cmd = [
    'uv', 'run', 'python', 'main.py',
    '--config', 'yaml/experiment/feature_set_aaforecast/brentoil-case1.yaml',
]
subprocess.run(cmd, cwd=REPO_ROOT, check=True, env={**os.environ, 'UV_CACHE_DIR': '/tmp/uv-cache'})

rows = list(csv.DictReader(FORECASTS.open()))
selected = []
for row in rows:
    if row['model'] != 'AAForecast':
        continue
    if row['fold_idx'] != '1':
        continue
    h = int(row['horizon_step'])
    if h not in THRESHOLDS:
        continue
    y = float(row['y'])
    y_hat = float(row['y_hat'])
    mape = abs(y - y_hat) / abs(y) * 100.0
    selected.append({
        'ds': row['ds'],
        'fold_idx': int(row['fold_idx']),
        'horizon_step': h,
        'y': y,
        'y_hat': y_hat,
        'mape': mape,
        'threshold': THRESHOLDS[h],
        'excess': mape - THRESHOLDS[h],
    })

if len(selected) != 3:
    raise SystemExit(f'Expected 3 Brent fold=1 h6-h8 rows, found {len(selected)}')

metric = max(item['excess'] for item in selected)
summary = {
    'metric_name': 'brent_fold1_h6_3_h7h8_5_threshold_gap_pct',
    'metric_value': metric,
    'stop_condition': 'metric <= 0',
    'window_definition': {'fold_idx': 1, 'horizon_steps': [6, 7, 8]},
    'thresholds': THRESHOLDS,
    'points': selected,
}
(OUT_DIR / 'brent_h6_h8_threshold_points.json').write_text(json.dumps(selected, indent=2), encoding='utf-8')
(OUT_DIR / 'summary_thresholds.json').write_text(json.dumps(summary, indent=2), encoding='utf-8')
print(metric)

