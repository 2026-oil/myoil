    def _blend_late_horizon_context(self, attended: torch.Tensor) -> torch.Tensor:
        if self.h <= 1:
            return attended
        late_context = attended[:, -1:, :].expand(-1, self.h, -1)
        ramp = torch.linspace(0.0, 1.0, steps=self.h, device=attended.device)
        ramp = ramp.pow(4)
        ramp = ramp.view(1, self.h, 1)
        return attended + (late_context - attended) * ramp

    def _late_trend_correction(self, insample_y: torch.Tensor) -> torch.Tensor:
        if insample_y.size(1) < 2:
            return torch.zeros(insample_y.size(0), self.h, 1, device=insample_y.device)
        recent_delta = insample_y[:, -1:, :] - insample_y[:, -2:-1, :]
        horizon_profile = torch.linspace(0.0, 1.0, steps=self.h, device=insample_y.device)
        horizon_profile = (6.0 * horizon_profile.pow(26)).view(1, self.h, 1)
        return recent_delta.expand(-1, self.h, -1) * horizon_profile

    def _event_mask(self, event_signal: torch.Tensor) -> torch.Tensor:
        event_center = event_signal.median(dim=1, keepdim=True).values
        event_mad = (
            (event_signal - event_center).abs().median(dim=1, keepdim=True).values
        ).clamp_min(1e-4)
        upward_shift = (event_signal - event_center).clamp_min(0.0)
        event_score = 0.6745 * upward_shift / event_mad
        return event_score > self.anomaly_threshold

    def forward(self, windows_batch):
        insample_y = windows_batch["insample_y"]
        hist_exog = windows_batch["hist_exog"]

        star = self.star(insample_y)
        encoder_parts = []
        if not self.exclude_insample_y:
            encoder_parts.append(insample_y)
        if self.hist_exog_size > 0:
            encoder_parts.append(hist_exog)
            event_signal = hist_exog[:, :, :1]
            event_mask = self._event_mask(event_signal)
        else:
            event_signal = torch.zeros_like(insample_y)
            event_mask = torch.zeros_like(insample_y, dtype=torch.bool)
