from __future__ import annotations

import csv
import json
import os
import subprocess
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[3]
RUN_DIR = REPO_ROOT / 'runs' / 'feature_set_aaforecast_brentoil_case1_aaforecast'
FORECASTS = RUN_DIR / 'cv' / 'AAForecast_forecasts.csv'
OUT_DIR = REPO_ROOT / '.omx' / 'research' / 'research-20260401-brent-aaf-h6h8' / 'autoresearch_eval'
OUT_DIR.mkdir(parents=True, exist_ok=True)

cmd = [
    'uv', 'run', 'python', 'main.py',
    '--config', 'yaml/experiment/feature_set_aaforecast/brentoil-case1.yaml',
]
subprocess.run(cmd, cwd=REPO_ROOT, check=True, env={**os.environ, 'UV_CACHE_DIR': '/tmp/uv-cache'})

rows = list(csv.DictReader(FORECASTS.open()))
selected = []
for row in rows:
    if row['model'] != 'AAForecast':
        continue
    if row['fold_idx'] != '1':
        continue
    step = int(row['horizon_step'])
    if step not in (7, 8):
        continue
    y = float(row['y'])
    y_hat = float(row['y_hat'])
    ape = abs(y - y_hat) / abs(y) * 100.0
    selected.append({
        'ds': row['ds'],
        'fold_idx': 1,
        'horizon_step': step,
        'y': y,
        'y_hat': y_hat,
        'ape': ape,
    })

if len(selected) != 2:
    raise SystemExit(f'Expected exactly 2 Brent fold=1 h7-h8 rows, found {len(selected)}')

metric = max(item['ape'] for item in selected)
summary = {
    'metric_name': 'brent_fold1_max_mape_h7_h8_pct',
    'metric_value': metric,
    'stop_condition': 'metric <= 5',
    'window_definition': {'fold_idx': 1, 'horizon_steps': [7, 8]},
    'points': selected,
    'mean_mape_h7_h8': sum(item['ape'] for item in selected) / len(selected),
}
(OUT_DIR / 'brent_h7_h8_points.json').write_text(json.dumps(selected, indent=2), encoding='utf-8')
(OUT_DIR / 'summary_h7_h8.json').write_text(json.dumps(summary, indent=2), encoding='utf-8')
print(metric)

